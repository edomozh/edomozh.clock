<Application x:Class="Edomozh.Clock.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:local="clr-namespace:Edomozh.Clock"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        
        <!-- System Tray Icon -->
        <tb:TaskbarIcon x:Key="TrayIcon"
                        ToolTipText="Edomozh Clock"
                        DoubleClickCommand="{x:Static local:App.OpenSettingsCommand}"
                        PreviewTrayContextMenuOpen="TrayIcon_PreviewTrayContextMenuOpen">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="EditModeMenuItem" Header="Edit Mode" IsCheckable="True"
                              Click="EditModeMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="Settings..." Click="SettingsMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="ExitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
        
    </Application.Resources>
</Application>
