<Window x:Class="Edomozh.Clock.Forms.SettingsForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clock Settings"
        Width="450"
        Height="660"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin"
                    Value="0,0,0,12"/>
            <Setter Property="Padding"
                    Value="8"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Margin"
                    Value="0,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin"
                    Value="0,4"/>
            <Setter Property="Height"
                    Value="28"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin"
                    Value="0,4"/>
            <Setter Property="Height"
                    Value="28"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin"
                    Value="0,6"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin"
                    Value="0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <GroupBox Header="Time Format">
                <StackPanel>
                    <CheckBox x:Name="Use24HourCheckBox"
                              Content="Use 24-hour format"/>
                    <CheckBox x:Name="ShowSecondsCheckBox"
                              Content="Show seconds"/>
                    <CheckBox x:Name="ShowDateCheckBox"
                              Content="Show date"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Custom format:"
                                   Grid.Column="0"
                                   Margin="0,0,8,0"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="CustomFormatTextBox"/>
                            <TextBlock x:Name="CustomFormatPlaceholder"
                                       Text="HH:mm:ss, dddd, MMMM d, tt"
                                       Foreground="Gray"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </Grid>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Appearance">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Font:"
                                   Grid.Row="0"
                                   Grid.Column="0"/>
                        <ComboBox x:Name="FontComboBox"
                                  Grid.Row="0"
                                  Grid.Column="1"/>

                        <TextBlock Text="Size:"
                                   Grid.Row="1"
                                   Grid.Column="0"/>
                        <StackPanel Orientation="Horizontal"
                                    Grid.Row="1"
                                    Grid.Column="1">
                            <Slider x:Name="FontSizeSlider"
                                    Width="200"
                                    Minimum="12"
                                    Maximum="200"
                                    TickFrequency="4"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="FontSizeSlider_ValueChanged"/>
                            <TextBlock x:Name="FontSizeLabel"
                                       Text="48"
                                       Margin="8,0,0,0"
                                       Width="30"/>
                        </StackPanel>

                        <TextBlock Text="Text color:"
                                   Grid.Row="2"
                                   Grid.Column="0"/>
                        <StackPanel Orientation="Horizontal"
                                    Grid.Row="2"
                                    Grid.Column="1">
                            <TextBox x:Name="TextColorTextBox"
                                     Width="80"
                                     Text="#FFFFFF"/>
                            <Rectangle x:Name="TextColorPreview"
                                       Width="24"
                                       Height="24"
                                       Margin="8,0,0,0"
                                       Stroke="Gray"
                                       StrokeThickness="1"/>
                        </StackPanel>

                        <TextBlock Text="Text opacity:"
                                   Grid.Row="3"
                                   Grid.Column="0"/>
                        <StackPanel Orientation="Horizontal"
                                    Grid.Row="3"
                                    Grid.Column="1">
                            <Slider x:Name="TextOpacitySlider"
                                    Width="200"
                                    Minimum="0"
                                    Maximum="1"
                                    TickFrequency="0.1"
                                    ValueChanged="TextOpacitySlider_ValueChanged"/>
                            <TextBlock x:Name="TextOpacityLabel"
                                       Text="100%"
                                       Margin="8,0,0,0"
                                       Width="40"/>
                        </StackPanel>

                        <TextBlock Text="BG opacity:"
                                   Grid.Row="4"
                                   Grid.Column="0"/>
                        <StackPanel Orientation="Horizontal"
                                    Grid.Row="4"
                                    Grid.Column="1">
                            <Slider x:Name="BgOpacitySlider"
                                    Width="200"
                                    Minimum="0"
                                    Maximum="1"
                                    TickFrequency="0.1"
                                    ValueChanged="BgOpacitySlider_ValueChanged"/>
                            <TextBlock x:Name="BgOpacityLabel"
                                       Text="0%"
                                       Margin="8,0,0,0"
                                       Width="40"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="General">
                <StackPanel>
                    <CheckBox x:Name="AlwaysOnTopCheckBox"
                              Content="Always on top"/>
                    <CheckBox x:Name="StartWithWindowsCheckBox"
                              Content="Start with Windows"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Theme Presets">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PresetsComboBox"
                                  Grid.Column="0"
                                  Margin="0,0,8,0"/>
                        <Button x:Name="LoadPresetButton"
                                Content="Load"
                                Grid.Column="1"
                                Width="60"
                                Height="25"
                                Margin="0,0,4,0"
                                Click="LoadPresetButton_Click"/>
                        <Button x:Name="SavePresetButton"
                                Content="Save"
                                Grid.Column="2"
                                Width="60"
                                Height="25"
                                Margin="0,0,4,0"
                                Click="SavePresetButton_Click"/>
                        <Button x:Name="DeletePresetButton"
                                Content="Delete"
                                Grid.Column="3"
                                Width="60"
                                Height="25"
                                Click="DeletePresetButton_Click"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button x:Name="OkButton"
                    Content="OK"
                    Width="60"
                    Height="25"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="60"
                    Height="25"
                    IsCancel="True"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
