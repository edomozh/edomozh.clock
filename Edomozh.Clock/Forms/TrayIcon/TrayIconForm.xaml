<Application x:Class="Edomozh.Clock.TrayIconForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:local="clr-namespace:Edomozh.Clock"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>

        <tb:TaskbarIcon x:Key="TrayIcon"
                        DoubleClickCommand="{x:Static local:TrayIconForm.OpenSettingsCommand}"
                        PreviewTrayContextMenuOpen="TrayIcon_PreviewTrayContextMenuOpen">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="EditModeMenuItem"
                            Header="Draggable"
                            IsCheckable="True"
                            Click="EditModeMenuItem_Click"/>
                    <MenuItem Header="Reset Position"
                            Click="ResetPositionMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="Settings..."
                            Click="SettingsMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit"
                            Click="ExitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

    </Application.Resources>
</Application>
