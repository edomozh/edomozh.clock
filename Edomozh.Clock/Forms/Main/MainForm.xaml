<Window x:Class="Edomozh.Clock.Forms.MainForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edomozh Clock"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        LocationChanged="Window_LocationChanged">
    
    <Border x:Name="ClockBorder"
            CornerRadius="8"
            Padding="0">
        <Border.Background>
            <SolidColorBrush x:Name="BackgroundBrush" Color="Black" Opacity="0"/>
        </Border.Background>
        
        <StackPanel>
            <TextBlock x:Name="TimeText"
                       Text="00:00:00"
                       FontFamily="Segoe UI"
                       FontSize="48"
                       FontWeight="Light"
                       HorizontalAlignment="Center">
                <TextBlock.Foreground>
                    <SolidColorBrush x:Name="TextBrush" Color="White" Opacity="1"/>
                </TextBlock.Foreground>
            </TextBlock>
            
            <TextBlock x:Name="DateText"
                       Text=""
                       FontFamily="Segoe UI"
                       FontSize="16"
                       FontWeight="Light"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed">
                <TextBlock.Foreground>
                    <SolidColorBrush x:Name="DateTextBrush" Color="White" Opacity="0.8"/>
                </TextBlock.Foreground>
            </TextBlock>
        </StackPanel>
    </Border>
</Window>
